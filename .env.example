# PortfolioLive 환경변수
# 이 파일을 .env로 복사한 후 값을 채워주세요.
# cp .env.example .env

# Gemini API
GEMINI_API_KEY=

# Database (Docker PostgreSQL)
POSTGRES_DB=portfoliolive
POSTGRES_USER=portfoliolive
# POSTGRES_PASSWORD: 강력한 랜덤 패스워드 필수.
# 'changeme', 'postgres', 'admin' 등 예측 가능한 값 절대 금지.
# 생성: openssl rand -base64 32
POSTGRES_PASSWORD=

# GitHub (Personal Access Token - repo read)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Admin
ADMIN_PASSWORD=

# Admin 세션 HMAC 서명 비밀키 (32자 이상 필수)
# 생성: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# SMTP Email (Gmail 앱 비밀번호)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
ADMIN_EMAIL=

# Ports (기존 서비스 충돌 방지용 private port)
WEB_PORT=3100
AGENT_PORT=3101
# POSTGRES_PORT: 호스트 측 dev 접근용 포트 (loopback 전용 바인딩).
# docker-compose.yml에서 127.0.0.1에만 바인딩됨. 절대 0.0.0.0으로 변경 금지.
# 외부 접근이 필요하면 SSH 터널 또는 VPN 경유.
POSTGRES_PORT=5433
