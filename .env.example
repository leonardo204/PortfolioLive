# PortfolioLive 환경변수
# 이 파일을 .env로 복사한 후 값을 채워주세요.
# cp .env.example .env

# Gemini API
GEMINI_API_KEY=

# Database (Docker PostgreSQL)
POSTGRES_DB=portfoliolive
POSTGRES_USER=portfoliolive
POSTGRES_PASSWORD=

# GitHub (Personal Access Token - repo read)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Admin
ADMIN_PASSWORD=

# SMTP Email (Gmail 앱 비밀번호)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
ADMIN_EMAIL=

# Ports (기존 서비스 충돌 방지용 private port)
WEB_PORT=3100
AGENT_PORT=3101
POSTGRES_PORT=5433
